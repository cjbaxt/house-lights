---
import "../styles/global.css";
import Nav from "../components/Nav";
import EditorUnlock from "../components/EditorUnlock";
import ClientRouter from "astro/components/ClientRouter.astro";
import fs from "fs";
import path from "path";

const raw = fs.readFileSync(path.resolve("src/content/about.md"), "utf-8");
const paragraphs = raw.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function(){var t=localStorage.getItem('hl_theme');if(t!=='default')document.documentElement.dataset.theme='dutch';})();
    </script>
    <ClientRouter />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About — house lights</title>
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.png" : "favicon-local.png"}`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.svg" : "favicon-local.svg"}`} />
    {import.meta.env.PUBLIC_STATIC_DATA === "true" && <link rel="alternate icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />}
    {import.meta.env.PUBLIC_STATIC_DATA === "true" && <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white min-h-screen dutch:bg-[#f5f3ef]">
    <Nav current="/about" client:load transition:persist />
    <EditorUnlock client:load transition:persist />
    <main class="max-w-2xl mx-auto px-4 md:px-8 pt-16 md:pt-20 pb-24 md:pb-8">
      <p class="font-serif text-2xl text-neutral-900 mt-4 mb-8 dutch:font-sans dutch:font-black dutch:uppercase dutch:text-xl dutch:tracking-tight dutch:text-[#1a1a1a]">About</p>
      <div class="space-y-5 text-sm text-neutral-700 leading-relaxed dutch:text-[#444]">
        {paragraphs.map((p) => {
          const lines = p.split("\n");
          const isList = lines.every((l) => l.trimStart().startsWith("- "));
          const render = (s: string) => s.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
          if (isList) {
            return (
              <ul class="list-disc list-outside pl-4 space-y-1.5">
                {lines.map((l) => <li set:html={render(l.replace(/^-\s+/, ""))} />)}
              </ul>
            );
          }
          return <p set:html={render(p)} />;
        })}
      </div>
      <div class="mt-12 pt-8 border-t border-neutral-100 dutch:border-[#ece7de] flex items-center justify-center">
        <span class="font-serif text-2xl text-neutral-200 dutch:text-[#ece7de] select-none">⁂</span>
      </div>
    </main>
  </body>
</html>
