---
import "../styles/global.css";
import Nav from "../components/Nav";
import EditorUnlock from "../components/EditorUnlock";
import ClientRouter from "astro/components/ClientRouter.astro";
import WatchlistFeed from "../components/WatchlistFeed";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function(){var t=localStorage.getItem('hl_theme');if(t)document.documentElement.dataset.theme=t;})();
    </script>
    <ClientRouter />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Watchlist — house lights</title>
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.png" : "favicon-local.png"}`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}${import.meta.env.PUBLIC_STATIC_DATA === "true" ? "favicon.svg" : "favicon-local.svg"}`} />
    {import.meta.env.PUBLIC_STATIC_DATA === "true" && <link rel="alternate icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />}
    {import.meta.env.PUBLIC_STATIC_DATA === "true" && <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white min-h-screen glow:bg-[#12111a]">
    <Nav current="/watchlist" client:load transition:persist />
    <EditorUnlock client:load transition:persist />
    <main class="max-w-3xl mx-auto px-4 md:px-8 pt-4 md:pt-20 pb-24 md:pb-8">
      <WatchlistFeed client:load />
    </main>
  </body>
</html>
